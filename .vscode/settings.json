{
  // dont use live server, use vite
  "liveServer.settings.port": 2137,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.exclude": {
    "**/node_modules": true
  },
  // settings for vite extension, vite config is inside vite.config.js
  "vite.port": 5500,
  "vite.autoStart": false,
  "vite.browserType": "system",
  "vite.buildCommand": "",
  "vite.devCommand": "pnpm run start"
}
