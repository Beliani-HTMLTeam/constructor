{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@api/*": ["src/old-api/*"],
      "@components/*": ["src/components/*"],
      "@config/*": ["src/config/*"],
      "@entities/*": ["src/entities/*"],
      "@helpers/*": ["src/helpers/*"],
      "@main/*": ["src/main/*"],
      "@data/*": ["src/main/data/*"],
      "@handlers/*": ["src/main/handlers/*"],
      "@services/*": ["src/old-api/services/*"],
      "@templates/*": ["src/templates/*"],
      "@utils/*": ["src/utils/*"],
      "@css/*": ["src/utils/css/*"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "include": ["auto-imports.d.ts", "**/*.js"]
}
